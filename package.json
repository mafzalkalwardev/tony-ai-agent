{
  "name": "tony-agent",
  "version": "2.4.0",
  "description": "TONY — Groq brain, MCP integrations, goal-driven agent, graphify, Obsidian brain, Charlie OS",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/gateway/server.js",
    "ui": "node src/gateway/server.js",
    "cli": "node src/cli.js",
    "chat": "node src/cli.js chat",
    "run": "node src/cli.js run",
    "remember": "node src/cli.js remember",
    "skills": "node src/cli.js skills",
    "test": "node scripts/test-tony.js",
    "dev": "node --watch src/gateway/server.js",
    "charlie": "node src/charlie-os/index.js boot",
    "charlie:status": "node src/charlie-os/index.js status",
    "charlie:graph": "node src/charlie-os/index.js graph",
    "charlie:build": "node src/charlie-os/index.js build",
    "graph": "node src/charlie-os/index.js graph",
    "integrations:init": "node scripts/init-integrations.js",
    "integrations:status": "node scripts/init-integrations.js --status",
    "playwright:mcp": "node scripts/playwright-mcp.js",
    "test:live": "node scripts/test-live.js",
    "codegraph:sync": "codegraph sync",
    "codegraph:index": "codegraph index"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ws": "^8.18.0"
