# TONY AI Agent configuration
PORT=8787
TONY_DATA_DIR=./data

# LLM provider: groq | gemini | openai | anthropic | ollama | mock
TONY_LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Google AI Studio (Gemini) — https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Ollama — fully local offline LLM (install from ollama.com)
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Voice — Deepgram STT + ElevenLabs TTS
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Agentic brain — Obsidian vault (local markdown knowledge graph)
OBSIDIAN_VAULT_PATH=./vault
OBSIDIAN_BRAIN_FOLDER=Agentic Brain

# MCP Integrations
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar
FIRECRAWL_API_KEY=
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REFRESH_TOKEN=
QUICKBOOKS_REALM_ID=
QUICKBOOKS_SANDBOX=true
HIGGSFIELD_API_KEY=
HIGGSFIELD_BASE_URL=https://platform.higgsfield.ai
PLAYWRIGHT_MCP_URL=http://localhost:8931/mcp
PLAYWRIGHT_MCP_PORT=8931
PLAYWRIGHT_MCP_HEADLESS=true

# Local-first: use graphify/repos/fetch when paid MCP keys missing
TONY_LOCAL_FIRST=true

# Offline local agent
TONY_OFFLINE_AUTO=true
TONY_OFFLINE_FORCE=false

# Task recorder — replay workflows offline ("repeat <name>")
TONY_AUTO_RECORD_TASKS=true
TONY_TASK_MIN_STEPS=2

# Goal-driven execution (Karpathy principle #4)
TONY_GOAL_MAX_ROUNDS=10
TONY_GOAL_AUTO_RUN=true

# Agent behavior
TONY_MAX_ITERATIONS=12
TONY_AUTO_REFLECT=true
TONY_WORKSPACE_ROOT=.

# Optional: path to other repos TONY can read (e.g. SignalMint)
# TONY_WORKSPACE_ROOT=D:\SMS Marketing App

# Integrations
SIGNALMINT_API_URL=http://localhost:5000
SIGNALMINT_EMAIL=super_admin@signalmint.local
SIGNALMINT_PASSWORD=password123
GITHUB_TOKEN=

# Security
TONY_API_TOKEN=change_me_tony_gateway_token

# Original tony-ai Python desktop assistant (https://github.com/mafzalkalwardev/tony-ai)
TONY_DESKTOP_ENABLED=true
# TONY_DESKTOP_PATH=./integrations/repos/tony-ai

# Shell safety (tony-ai policy). Set true only for trusted dev machines.
TONY_SHELL_UNSAFE=false

# Extended MCP servers (optional — start with npm run mcp:stack)
OPENWIKI_MCP_URL=
OPENWIKI_DOCS_URL=http://localhost:8090
SCRAPER_MEDIA_MCP_URL=
MOTIONGRAPH_MCP_URL=

# 24/7 daemon — continuous gateway + goal ticks + graph rebuild
TONY_DAEMON_ENABLED=false
TONY_DAEMON_AUTO_GOALS=true
TONY_DAEMON_INTERVAL_MS=300000
TONY_DAEMON_GRAPH_MS=3600000
